{
  "name": "@gui-chat-plugin/mulmocast",
  "version": "1.1.0",
  "description": "Mulmocast presentation plugin for GUI Chat applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mulmocast/types": "^2.9.0",
    "mulmocast": "^2.9.0",
    "mulmocast-viewer": "^0.2.4",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vue": "^3.5.40",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.8",
    "gui-chat-protocol": "^1.2.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "gui-chat-protocol": "^1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/receptron/GUIChatPluginMulmocast.git"
  },
  "license": "MIT",
  "resolutions": {
    "@hono/node-server": "^2.0.5"
  }
}
